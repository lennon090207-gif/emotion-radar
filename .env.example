# Copy to .env (or write to /root/.hermes/.env on the VPS) and fill in.
# Never commit the real .env.

APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vision analysis (Phase 2). Set ONE of these.
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Optional vision overrides.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
#
# Recommended models from real VPS testing on the Oliver canary:
#   - Pass 1 (visual event): Gemini 2.5 Flash — only model that consistently
#     identified the cross-frame object motion (pick up / drop / break).
#   - Pass 2 (hook strategy): GPT-4o — solid text reasoner; prompt now
#     hard-binds it to Pass 1 evidence so soft mechanics are blocked.
# VISION_EVENT_MODEL=google/gemini-2.5-flash
# HOOK_STRATEGY_MODEL=gpt-4o
#
# Or set a single model for both passes:
# VISION_MODEL=gpt-4o

# Optional storage overrides.
# EMOTION_RADAR_DB=data/emotion_radar.db
# EMOTION_RADAR_DATA_DIR=data
